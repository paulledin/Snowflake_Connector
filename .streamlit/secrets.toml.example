# ── Snowflake key-pair credentials ───────────────────────────────────────────
[snowflake]
user = "your_snowflake_username"
private_key = """
-----BEGIN PRIVATE KEY-----
<paste your unencrypted private key content here>
-----END PRIVATE KEY-----
"""
# Optional — only needed if your private key was generated with a passphrase
# private_key_passphrase = "your_passphrase"

# ── Auth0 OIDC (required on Streamlit Cloud; handled via .env locally) ────────
[auth]
redirect_uri  = "https://<your-app>.streamlit.app/oauth2callback"
cookie_secret = "<random string>"

[auth.auth0]
client_id             = "<Auth0 Client ID>"
client_secret         = "<Auth0 Client Secret>"
server_metadata_url   = "https://<your-tenant>.auth0.com/.well-known/openid-configuration"
client_kwargs         = { prompt = "login" }
